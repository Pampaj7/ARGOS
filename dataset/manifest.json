{
  "version": 2,
  "purpose": "Local data home for ARGOS: curated experiment subsets, raw source archives, and processed workspace data.",
  "git_policy": {
    "tracked": [
      "dataset/README.md",
      "dataset/manifest.json",
      "small curated subsets when useful for reproducibility"

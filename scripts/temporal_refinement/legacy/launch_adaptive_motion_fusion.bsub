#!/bin/bash
#BSUB -J argos_fusion
#BSUB -q p1
#BSUB -gpu "num=2:mode=shared"
#BSUB -n 8
#BSUB -R "span[hosts=1]"
#BSUB -R "rusage[mem=16GB]"
#BSUB -W 24:00
#BSUB -o results/03_temporal_refinement/training/adaptive_motion_fusion/live_run_v3/lsf_%J.out
#BSUB -e results/03_temporal_refinement/training/adaptive_motion_fusion/live_run_v3/lsf_%J.err

cd /dtu/p1/leopam/ARGOS
export PYTHONPATH="$(pwd)"
export OMP_NUM_THREADS=4

mkdir -p results/03_temporal_refinement/training/adaptive_motion_fusion/live_run_v3

.miniconda/envs/argos/bin/torchrun \
    --nproc_per_node=2 \
    scripts/temporal_refinement/train_adaptive_motion_fusion.py \
    --out-dir results/03_temporal_refinement/training/adaptive_motion_fusion/live_run_v3 \
    --epochs 240 \
    --batch-size 8 \
    --eval-every 5 \
    --save-every 10 \
    --num-workers 8
